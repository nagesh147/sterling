ENVIRONMENT=development
PAPER_TRADING=true
REAL_PUBLIC_DATA=true
DEFAULT_UNDERLYING=BTC
EXCHANGE_ADAPTER=deribit
DERIBIT_BASE_URL=https://www.deribit.com/api/v2
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
MAX_CONTRACTS=10
MAX_POSITION_PCT=0.05
DEFAULT_CAPITAL=100000.0
# Exchange credentials (optional — public data works without keys)
DELTA_API_KEY=
DELTA_API_SECRET=

# Sterling DB
STERLING_DB_PATH=sterling_paper.db

# Phase 1 — Trading mode
STERLING_DEFAULT_MODE=swing

# Phase 5 — Telegram notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Phase 6 — Circuit breakers
STERLING_DAILY_LOSS_LIMIT=0.05
STERLING_MARGIN_FLOOR=0.20
STERLING_MAX_CONSECUTIVE_LOSSES=5
